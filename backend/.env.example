# Configurações do Servidor
PORT=3001
NODE_ENV=development

# Banco de Dados MySQL (Hostinger)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=pacotinho_de_amor
DB_USER=seu_usuario
DB_PASSWORD=sua_senha

# JWT Secret (use uma string longa e aleatória em produção)
JWT_SECRET=sua_chave_secreta_jwt_aqui_trocar_em_producao
JWT_EXPIRES_IN=7d

# URL do Frontend (para CORS)
FRONTEND_URL=http://localhost:5173

# Upload de imagens
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880
